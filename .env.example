# 羽扬日记 — environment variables
#
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit real keys.
#
# The app currently runs entirely on browser localStorage.
# These variables are only used after we flip the cloud feature flag below.

# Supabase project URL, e.g. https://abcd1234.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — safe to expose to the browser.
# Never put the service-role key in this file or anywhere shipped to the client.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloud sync feature flag. Must be the literal string "true" to enable.
# Default is "false" — the app stays on localStorage.
NEXT_PUBLIC_CLOUD_ENABLED=false
