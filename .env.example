# 羽扬日记 — environment variables
#
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit real keys.
#
# The app currently runs entirely on browser localStorage.
# These variables are only used after we flip the cloud feature flag below.

# Supabase project URL, e.g. https://abcd1234.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable (browser-safe) key.
# Either of these env names works — pick whichever your Supabase dashboard
# exposes. Newer projects show "PUBLISHABLE_KEY" (sb_publishable_...).
# Older projects show "ANON_KEY" (eyJ... JWT). Both are safe to ship to the
# browser; RLS is what gates real access.
#
# IMPORTANT: never put the service-role / "secret" key in this file.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# (legacy alias, also accepted)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloud sync feature flag. Must be the literal string "true" to enable.
# Default is "false" — the app stays on localStorage.
NEXT_PUBLIC_CLOUD_ENABLED=false
